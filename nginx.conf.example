# /etc/nginx/sites-available/amazon-tool
#
# Install:
#   cp nginx.conf.example /etc/nginx/sites-available/amazon-tool
#   ln -sf /etc/nginx/sites-available/amazon-tool /etc/nginx/sites-enabled/amazon-tool
#   nginx -t && systemctl reload nginx
#
# Keep sites-enabled/amazon-tool a SYMLINK, never a copy. On 2026-07-10 the two
# had silently diverged: nginx was serving sites-enabled while every edit landed
# in sites-available, so `nginx -t` passed and nothing changed. Verify with:
#   ls -l /etc/nginx/sites-enabled/amazon-tool     # expect  l...  -> ../sites-available/...
#
# TLS is terminated by Cloudflare. This server only ever listens on port 80.
# Do NOT add an http->https or apex->www redirect here: with Cloudflare's
# Flexible SSL mode the origin always sees $scheme = http, so a redirect keyed on
# $scheme becomes an infinite loop. Those two redirects belong in Cloudflare.
# See the frontend repo, docs/seo-redirects.md.

server {
    listen 80;
    server_name thewholesaleos.com www.thewholesaleos.com YOUR_SERVER_IP;

    # Cloudflare terminates TLS, so nginx believes every request arrived over
    # http and builds absolute redirects as http://, downgrading the client.
    # Relative Location headers preserve whatever scheme the browser used.
    absolute_redirect off;

    # The frontend deploy scps dist/* with strip_components: 1, so the built
    # files land here directly -- not in a dist/ subdirectory.
    root /var/www/amazon-frontend;
    index index.html;

    # ── Block dotfiles and anything that must never leave the web root ──────
    location ~ /\. {
        deny all;
        return 404;
    }

    location ~* \.(sql|bak|map|env|log|sh|key|pem|crt|conf|config|lock)$ {
        deny all;
        return 404;
    }

    location ~ ^/(prisma|node_modules|\.git|\.github)/ {
        deny all;
        return 404;
    }

    # ── Frontend (prerendered React build) ─────────────────────────────────
    location / {
        # The public marketing routes are prerendered to real files:
        #   /        -> index.html
        #   /faq     -> faq/index.html
        #   /sign-in -> sign-in/index.html
        #
        # `$uri/` would match the *directory* faq/, and nginx's index module
        # answers a slash-less directory request with a 301 to /faq/. Every
        # canonical tag and sitemap entry says /faq, so that redirect was both a
        # wasted hop and a canonical mismatch. Match the file directly instead.
        #
        # Anything that matches no file still falls back to the SPA shell, which
        # is how /dashboard and /admin keep working.
        try_files $uri $uri/index.html /index.html;
    }

    # ── Backend API (proxied to Node on port 3001) ─────────────────────────
    location /api/ {
        proxy_pass         http://localhost:3001;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    location /health {
        proxy_pass http://localhost:3001;
    }

    # ── Gzip ───────────────────────────────────────────────────────────────
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
}
