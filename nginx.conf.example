# /etc/nginx/sites-available/amazon-tool
# Copy this file to /etc/nginx/sites-available/amazon-tool
# then: ln -s /etc/nginx/sites-available/amazon-tool /etc/nginx/sites-enabled/

server {
    listen 80;
    server_name YOUR_DOMAIN_OR_IP;

    # ── Frontend (React build) ─────────────────────────────────
    root /var/www/amazon-frontend;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # ── Backend API (proxied to Node on port 3001) ─────────────
    location /api/ {
        proxy_pass         http://localhost:3001;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_cache_bypass $http_upgrade;
    }

    location /health {
        proxy_pass http://localhost:3001;
    }

    # ── Gzip ───────────────────────────────────────────────────
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
}
