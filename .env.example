# Copy to .env and fill in. NEVER commit the real .env -- it is gitignored.
#
# Every variable below is validated on boot by config/env.js (zod). If one is
# missing or malformed the process exits rather than starting half-configured,
# so a typo here is a startup failure, not a silent runtime bug.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-free single origin the browser will call from. In production this is the
# real site, over https -- not the droplet's raw IP.
CORS_ORIGIN=https://www.thewholesaleos.com

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Required.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE

# ── Auth ─────────────────────────────────────────────────────────────────────
# BOTH secrets are required and must be at least 32 characters.
# They must be DIFFERENT from each other: if one leaks, the other still holds.
# Generate each with:  openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_REFRESH_SECRET=REPLACE_WITH_A_DIFFERENT_openssl_rand_hex_32

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Third-party ──────────────────────────────────────────────────────────────
# Keepa API key -- the product data the whole app is built on.
# Server-side only. Never expose this to the browser.
KEEPA_API_KEY=REPLACE_WITH_YOUR_KEEPA_KEY

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated emails that get admin access. Leave empty for none.
ADMIN_EMAILS=you@example.com
