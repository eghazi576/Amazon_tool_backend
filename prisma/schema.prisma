// Prisma Schema — Amazon Insight Hub
// Converted from schema.sql (Supabase → PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt hashed
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  resetPasswordToken  String?   @map("reset_password_token")
  resetPasswordExpiry DateTime? @map("reset_password_expiry")

  searches      AsinSearch[]
  brandSearches BrandSearch[]
  refreshTokens RefreshToken[]

  @@map("users")
}

// ─── Refresh Tokens ───────────────────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── ASIN Search History ──────────────────────────────────────────────────────
model AsinSearch {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Product info
  asin     String
  title    String?
  brand    String?
  image    String?
  category String?

  // Pricing
  sellingPrice   Float?  @map("selling_price")
  medianPrice90d Float?  @map("median_price_90d")

  // Profit analysis
  profitPerUnit Float?  @map("profit_per_unit")
  roiPct        Float?  @map("roi_pct")
  marginPct     Float?  @map("margin_pct")
  referralFee   Float?  @map("referral_fee")
  fbaFee        Float?  @map("fba_fee")
  storageFee    Float?  @map("storage_fee")
  totalFees     Float?  @map("total_fees")
  cogs          Float?
  breakEvenPrice Float? @map("break_even_price")

  // Scoring
  decision   String? // EXCELLENT | GOOD | AVERAGE | BAD | REJECT
  score      Int?
  maxScore   Int?    @map("max_score")
  scorePct   Float?  @map("score_pct")

  // Rejection
  rejectionReasons String[] @map("rejection_reasons")

  // Metrics
  currentBsr       Int?    @map("current_bsr")
  avgBsr90d        Int?    @map("avg_bsr_90d")
  rating           Float?
  reviewCount      Int?    @map("review_count")
  fbaSellerCount   Int?    @map("fba_seller_count")
  monthlySalesEst  Int?    @map("monthly_sales_est")
  monthlyRevenue   Float?  @map("monthly_revenue")
  isHazmat         Boolean @default(false) @map("is_hazmat")
  amazonIsSeller   Boolean @default(false) @map("amazon_is_seller")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([asin])
  @@index([createdAt])
  @@map("asin_searches")
}

// ─── Brand Intelligence History ───────────────────────────────────────────────
model BrandSearch {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Brand identity
  asin         String
  brandName    String  @map("brand_name")
  brandWebsite String? @map("brand_website")
  category     String?

  // Scoring result
  decision         String   // APPROVED | REJECTED
  score            Int
  maxScore         Int     @map("max_score")
  scorePct         Float   @map("score_pct")
  rejected         Boolean
  rejectionReasons String[] @map("rejection_reasons")
  explanation      String?

  // Input snapshot
  hasRegisteredBusiness Boolean @map("has_registered_business")
  hazmatHeavyCatalog    Boolean @map("hazmat_heavy_catalog")
  adultOrHighRisk       Boolean @map("adult_or_high_risk")
  massAccountTakedowns  Boolean @map("mass_account_takedowns")
  lastSaleWithin30Days  Boolean @map("last_sale_within_30_days")
  ipComplaintsLast12Mo  Int     @default(0) @map("ip_complaints_last_12_mo")
  ipAlertRedFlags       Boolean @default(false) @map("ip_alert_red_flags")
  fbaSellersPerAsin     Int?    @map("fba_sellers_per_asin")
  monthlySalesPerAsin   Int?    @map("monthly_sales_per_asin")
  mapViolationSensitive Boolean @default(false) @map("map_violation_sensitive")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([brandName])
  @@index([createdAt])
  @@map("brand_searches")
}

// ─── App Config (admin-controlled settings) ───────────────────────────────────
model AppConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_configs")
}
